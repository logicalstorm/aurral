diff --git a/node_modules/slsk-client/lib/peer/upload-peer-file.js b/node_modules/slsk-client/lib/peer/upload-peer-file.js
new file mode 100644
index 0000000..6971c89
--- /dev/null
+++ b/node_modules/slsk-client/lib/peer/upload-peer-file.js
@@ -0,0 +1,52 @@
+const fs = require('fs')
+const debug = require('debug')('slsk:peer:upload:i')
+
+let stack = require('../stack')
+
+module.exports = (socket, token, shared) => {
+  const upload = stack.uploadTokens[token]
+  const sharedFile = upload && shared && typeof shared.findFile === 'function'
+    ? shared.findFile(upload.file)
+    : null
+  const realPath = sharedFile ? sharedFile.realPath : upload ? upload.file : null
+
+  if (!realPath) {
+    debug(`No upload token or shared file found for ${token}`)
+    socket.destroy()
+    return
+  }
+
+  let started = false
+  const cleanup = () => {
+    delete stack.uploadTokens[token]
+  }
+
+  const startUpload = () => {
+    if (started) return
+    started = true
+    const stream = fs.createReadStream(realPath)
+    stream.on('error', error => {
+      debug(`Upload stream failed for ${realPath}: ${error.message}`)
+      cleanup()
+      socket.destroy()
+    })
+    stream.on('end', () => {
+      cleanup()
+      socket.end()
+    })
+    socket.on('error', () => {
+      stream.destroy()
+      cleanup()
+    })
+    socket.on('close', () => {
+      stream.destroy()
+      cleanup()
+    })
+    stream.pipe(socket, { end: false })
+  }
+
+  socket.on('data', () => {
+    startUpload()
+  })
+  setTimeout(startUpload, 200)
+}
