{
  "name": "aurral-backend",
  "version": "1.76.0",
  "description": "Backend API for Aurral artist request manager",
  "private": true,
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "node --watch --env-file=.env server.js",
