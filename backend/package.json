{
  "name": "aurral-backend",
  "version": "1.76.0",
  "description": "Backend API for Aurral artist request manager",
  "private": true,
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "auth:reset-admin-password": "node scripts/resetAdminPassword.js"
  },
  "keywords": [
    "musicbrainz",
    "music",
    "request"
  ],
  "author": "",
  "license": "MIT",
  "nodemonConfig": {
    "ignore": [
      "data/db.json"
    ]
  },
  "optionalDependencies": {
    "@russellthehippo/honker-node-darwin-arm64": "0.3.3",
    "@russellthehippo/honker-node-darwin-x64": "0.3.3",
    "@russellthehippo/honker-node-linux-arm64-gnu": "0.3.3",
    "@russellthehippo/honker-node-linux-x64-gnu": "0.3.3"
  },
  "dependencies": {
    "@russellthehippo/honker-node": "^0.3.3",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "music-metadata": "^11.12.3",
    "node-cache": "^5.1.2",
    "sharp": "^0.34.5",
    "ws": "^8.21.0"
  }
}
