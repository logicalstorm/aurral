{
  "name": "aurral-backend",
  "version": "1.76.0",
  "description": "Backend API for Aurral artist request manager",
  "private": true,
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx watch server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "auth:reset-admin-password": "tsx scripts/resetAdminPassword.ts"
  },
  "keywords": [
    "musicbrainz",
    "music",
    "request"
  ],
  "author": "",
  "license": "MIT",
  "nodemonConfig": {
    "ignore": [
      "data/db.json"
    ]
  },
  "optionalDependencies": {
    "@russellthehippo/honker-node-darwin-arm64": "0.3.3",
    "@russellthehippo/honker-node-darwin-x64": "0.3.3",
    "@russellthehippo/honker-node-linux-arm64-gnu": "0.3.3",
    "@russellthehippo/honker-node-linux-x64-gnu": "0.3.3"
  },
  "dependencies": {
    "@russellthehippo/honker-node": "^0.3.3",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "music-metadata": "^11.12.3",
    "node-cache": "^5.1.2",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
