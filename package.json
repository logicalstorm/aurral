{
  "name": "aurral",
  "version": "1.76.0",
  "description": "Aurral artist request manager",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspace frontend",
    "start": "tsx backend/server.ts",
    "test": "node --import tsx --test --test-concurrency=1 $(find .tests -name '*.test.ts' -print)",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:backend\" \"npm run wait-and-dev:frontend\"",
    "wait-and-dev:frontend": "wait-on -t 15000 http://localhost:3001/api/health && npm run dev --workspace frontend",
    "dev:backend": "nodemon --exec tsx backend/server.ts",
    "dev:frontend": "npm run dev --workspace frontend",
    "auth:reset-admin-password": "npm run auth:reset-admin-password --workspace backend",
    "docker:build": "docker build -t aurral .",
    "docker:run": "docker run -p 3001:3001 -v $(pwd)/backend/data:/app/backend/data aurral",
    "desktop:dev": "npm run dev --prefix desktop",
    "desktop:build": "npm run build --prefix desktop",
    "desktop:sync-version": "npm run sync-version --prefix desktop",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:backend": "npm run lint --workspace backend",
    "docs:dev": "npm run dev --prefix docs",
    "docs:build": "npm run build --prefix docs",
    "hooks:install": "sh scripts/install-git-hooks.sh",
    "prepare": "if [ -d .git ] && [ -f scripts/install-git-hooks.sh ]; then sh scripts/install-git-hooks.sh; fi"
  },
  "keywords": [
    "lidarr",
    "musicbrainz",
    "music",
    "request"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^10.0.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "sharp": "^0.34.5",
    "wait-on": "^9.0.10"
  },
  "nodemonConfig": {
    "watch": [
      "backend",
      "backend/server.ts"
    ],
    "ext": "js,ts,json",
    "ignore": [
      "node_modules",
      "frontend",
      "backend/data",
      "*.log",
      "frontend/dist"
    ],
    "delay": 2000,
    "restartable": "rs"
  }
}
