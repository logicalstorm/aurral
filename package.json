{
  "name": "aurral",
  "version": "1.76.0",
  "description": "Aurral artist request manager",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspace frontend",
    "start": "node --env-file=backend/.env backend/server.js",
    "test": "node --test --test-concurrency=1 $(find .tests -name '*.int.test.js' -print) && node --test --test-concurrency=4 $(find .tests -name '*.test.js' -not -name '*.int.test.js' -print)",
    "test:coverage": "node --experimental-test-coverage --test --test-concurrency=1 --test-coverage-include='backend/**' --test-coverage-lines=30 $(find .tests -name '*.int.test.js' -print) && node --experimental-test-coverage --test --test-concurrency=4 --test-coverage-include='backend/**' --test-coverage-lines=30 $(find .tests -name '*.test.js' -not -name '*.int.test.js' -print)",
    "dev": "npm run dev:backend & (npm run wait-and-dev:frontend) & wait",
    "wait-and-dev:frontend": "while ! curl -s http://localhost:3001/api/health; do sleep 1; done && npm run dev --workspace frontend",
    "dev:backend": "node --watch --env-file=backend/.env backend/server.js",
    "dev:frontend": "npm run dev --workspace frontend",
    "auth:reset-admin-password": "npm run auth:reset-admin-password --workspace backend",
    "docker:build": "docker build -t aurral .",
    "docker:run": "docker run -p 3001:3001 -v $(pwd)/backend/data:/app/backend/data aurral",
    "desktop:dev": "npm run dev --prefix desktop",
    "desktop:build": "npm run build --prefix desktop",
    "desktop:sync-version": "npm run sync-version --prefix desktop",
    "docs:dev": "npm run dev --prefix docs",
    "docs:build": "npm run build --prefix docs",
    "hooks:install": "sh scripts/install-git-hooks.sh",
    "prepare": "if [ -d .git ] && [ -f scripts/install-git-hooks.sh ]; then sh scripts/install-git-hooks.sh; fi"
  },
  "keywords": [
    "lidarr",
    "musicbrainz",
    "music",
    "request"
  ],
  "author": "",
  "license": "MIT"
}
